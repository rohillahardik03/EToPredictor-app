<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETo Predictor"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="20sp"
                    android:letterSpacing="0.03"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvScreenSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual Input"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.6"
                    android:textSize="12sp"
                    android:letterSpacing="0.06" />
            </LinearLayout>

            <!-- ic_moon shown in light mode, ic_sun shown in dark mode (set from Kotlin) -->
            <ImageButton
                android:id="@+id/btnThemeToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_moon"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Toggle Theme" />

        </LinearLayout>

        <!-- Auto-fetch Status Banner -->
        <LinearLayout
            android:id="@+id/cardAutoStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/bg_status_banner"
            android:layout_marginBottom="18dp"
            android:visibility="gone">

            <!-- Top row: spinner + status text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ProgressBar
                    android:id="@+id/progressAutoFetch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminateTint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvAutoStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Fetching location weather data..."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <!-- Location coordinates shown below status text -->
            <TextView
                android:id="@+id/tvLocationUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginTop="6dp"
                android:layout_marginStart="32dp" />

        </LinearLayout>

        <!-- Section Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WEATHER PARAMETERS"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6"
            android:layout_marginBottom="12dp" />

        <!-- Input Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_box_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvInputHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter at least 2 values. Missing values will be auto-estimated."
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6"
                android:layout_marginBottom="16dp" />

            <!-- Row 1 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Sunshine Hours  n  (0 - 15 hrs)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSunshine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Row 2 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Max Temperature  Tmax  (°C)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTmax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Row 3 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Min Temperature  Tmin  (°C)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Row 4 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Max Relative Humidity  RHmax  (%)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRHmax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Row 5 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Min Relative Humidity  RHmin  (%)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="14dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRHmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Row 6 -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Wind Speed  u  (m/s)"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeColor="?attr/colorPrimary"
                android:layout_marginBottom="20dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWind"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Predict Button -->
            <Button
                android:id="@+id/btnPredict"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="PREDICT ETo"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="@android:color/white"
                android:layout_marginBottom="10dp" />

            <!-- Clear Button — outlined style, no bright background -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="CLEAR"
                android:textSize="13sp"
                android:letterSpacing="0.08"
                app:strokeColor="?attr/colorPrimary"
                android:textColor="?attr/colorPrimary" />

        </LinearLayout>

        <!-- Loading Card -->
        <LinearLayout
            android:id="@+id/loadingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center"
            android:background="@drawable/bg_box_card"
            android:visibility="gone"
            android:layout_marginBottom="12dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CALCULATING ETo..."
                android:textSize="12sp"
                android:letterSpacing="0.10"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.7"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <!-- Result Card -->
        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp"
            android:gravity="center"
            android:background="@drawable/bg_box_card"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESULT"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvEtoValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="68sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mm / day"
                android:textSize="16sp"
                android:letterSpacing="0.05"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_light"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/tvEtoLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="6dp"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tvParamsUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.6" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
