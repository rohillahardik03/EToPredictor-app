<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- ══ HEADER BAR ══ -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:background="@drawable/bg_gradient_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#AAFF00"
            android:contentDescription="Back" />

        <!-- Title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETo Predictor"
                android:textColor="#AAFF00"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScreenSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual Input"
                android:textColor="#8000E5FF"
                android:textSize="12sp"
                android:letterSpacing="0.10" />

        </LinearLayout>

        <!-- Theme Toggle -->
        <ImageButton
            android:id="@+id/btnThemeToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_day"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#00E5FF"
            android:contentDescription="Toggle Theme" />

    </LinearLayout>

    <!-- ══ AUTO STATUS BANNER ══ -->
    <LinearLayout
        android:id="@+id/cardAutoStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_status_banner"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressAutoFetch"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="#00E5FF" />

        <TextView
            android:id="@+id/tvAutoStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Fetching location weather data..."
            android:textSize="12sp"
            android:textColor="#00E5FF" />

        <TextView
            android:id="@+id/tvLocationUsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/text_hint"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ══ HINT TEXT ══ -->
    <TextView
        android:id="@+id/tvInputHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter at least 2 values · Missing ones are auto-estimated"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:letterSpacing="0.04"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardAutoStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ══ 2x3 INPUT GRID ══ -->
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/inputGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:columnCount="2"
        app:rowCount="3"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvInputHint"
        app:layout_constraintBottom_toTopOf="@id/btnRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ☀️ Sunshine Hours -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="0"
            app:layout_row="0"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="☀️ Sunshine n (hrs)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_lime"
                app:hintTextColor="@color/neon_lime"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSunshine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 🌡️ Tmax -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="1"
            app:layout_row="0"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="🌡️ Tmax (°C)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_lime"
                app:hintTextColor="@color/neon_lime"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTmax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ❄️ Tmin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="0"
            app:layout_row="1"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="❄️ Tmin (°C)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_cyan"
                app:hintTextColor="@color/neon_cyan"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal|numberSigned"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 💧 RHmax -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="1"
            app:layout_row="1"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="💧 RHmax (%)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_cyan"
                app:hintTextColor="@color/neon_cyan"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRHmax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 🌫️ RHmin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="0"
            app:layout_row="2"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="🌫️ RHmin (%)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_lime"
                app:hintTextColor="@color/neon_lime"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRHmin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- 💨 Wind -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_column="1"
            app:layout_row="2"
            app:layout_columnWeight="1"
            app:layout_rowWeight="1">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="💨 Wind u (m/s)"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxStrokeColor="@color/neon_cyan"
                app:hintTextColor="@color/neon_cyan"
                app:boxStrokeWidth="1.5dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWind"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </androidx.gridlayout.widget.GridLayout>

    <!-- ══ BOTTOM BUTTON ROW ══ -->
    <LinearLayout
        android:id="@+id/btnRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Clear -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="CLEAR"
            android:textSize="13sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="?attr/colorPrimaryContainer"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:stateListAnimator="@null"
            android:layout_marginEnd="10dp"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- Predict -->
        <Button
            android:id="@+id/btnPredict"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="⚡  PREDICT ETo"
            android:textSize="15sp"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_predict_btn"
            android:textColor="#0A0E1A"
            android:stateListAnimator="@null"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- ══ LOADING OVERLAY (centered card) ══ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/loadingCard"
        android:layout_width="180dp"
        android:layout_height="150dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="?attr/colorSurface"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:indeterminateTint="@color/neon_lime" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CALCULATING..."
                android:textSize="12sp"
                android:letterSpacing="0.12"
                android:textColor="@color/neon_lime"
                android:layout_marginTop="14dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ══ HIDDEN RESULT VIEWS (used by BottomSheet binding) ══ -->
    <LinearLayout
        android:id="@+id/resultCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:id="@+id/tvEtoValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--" />
        <TextView android:id="@+id/tvEtoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />
        <TextView android:id="@+id/tvParamsUsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
