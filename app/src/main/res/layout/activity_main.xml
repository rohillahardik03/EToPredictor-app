<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- ══ HERO HEADER ══ -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:background="@drawable/bg_gradient_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardModeSelect"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Neon glow icon ring -->
        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_icon_ring" />

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#AAFF00"
                android:contentDescription="ETo icon" />

        </FrameLayout>

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ETo Predictor"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:textColor="#AAFF00" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EVAPOTRANSPIRATION · FAO-56"
            android:textSize="11sp"
            android:letterSpacing="0.20"
            android:textColor="#8000E5FF"
            android:layout_marginTop="8dp" />

        <!-- Thin neon divider -->
        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="#AAFF00"
            android:alpha="0.6"
            android:layout_marginTop="18dp" />

    </LinearLayout>

    <!-- ══ MODE SELECTION CARD ══ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardModeSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:layout_constraintTop_toBottomOf="@id/heroHeader"
        app:layout_constraintBottom_toTopOf="@id/tvFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT INPUT MODE"
                android:textSize="11sp"
                android:letterSpacing="0.20"
                android:textColor="?attr/colorSecondary"
                android:layout_marginBottom="22dp" />

            <!-- Manual Input Button -->
            <Button
                android:id="@+id/btnYes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✏️   MANUAL INPUT"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_predict_btn"
                android:textColor="#0A0E1A"
                android:stateListAnimator="@null"
                android:layout_marginBottom="14dp" />

            <!-- Divider with OR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#22AAFF00" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR  "
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_hint" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#22AAFF00" />

            </LinearLayout>

            <!-- GPS Button -->
            <Button
                android:id="@+id/btnNo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📍   AUTO FETCH FROM GPS"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ══ FOOTER ══ -->
    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Powered by Open-Meteo · FAO Penman-Monteith"
        android:textSize="10sp"
        android:letterSpacing="0.08"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
